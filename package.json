{
  "name": "MyraNative",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "node scripts/fix-calendar-assets.js",
    "pods": "bundle exec pod install --project-directory=ios",
    "clean": "rm -rf node_modules ios/Pods ios/build ~/Library/Developer/Xcode/DerivedData/MyraNative-* && npm install && bundle exec pod install --project-directory=ios",
    "backend": "cd backend && node index.js",
    "ai": "cd backend && source .venv/bin/activate && uvicorn app:app --host 0.0.0.0 --port 5002 --reload"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-picker/picker": "^2.11.4",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "axios": "^1.13.6",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-calendars": "^1.1314.0",
    "react-native-config": "^1.6.1",
    "react-native-filament": "^1.9.0",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-image-picker": "^8.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
