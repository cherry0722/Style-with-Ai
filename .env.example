# ─────────────────────────────────────────────────────────────────────────────
# MYRA — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mobile app (react-native-config) ─────────────────────────────────────────
# Read at build time by react-native-config.
# In dev/simulator the app falls back to localhost automatically if left empty.
API_URL=http://localhost:5001
AI_BASE_URL=http://localhost:5002
ENABLE_AI=true

# ── Node.js Backend ───────────────────────────────────────────────────────────
JWT_SECRET=
MONGO_URI=
MONGO_DB=style_with_ai
NODE_PORT=5001
INTERNAL_TOKEN=
AI_SERVICE_URL=http://127.0.0.1:5002
AI_TIMEOUT_MS=180000

# ── Python AI Service ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Python service runs on port 5002 via: uvicorn app:app --port 5002

# ── Cloudflare R2 (image upload — optional for local dev) ─────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
RAW_R2_PREFIX=raw/
CLEAN_R2_PREFIX=clean/
