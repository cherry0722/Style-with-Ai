# ─────────────────────────────────────────────────────────────────────────────
# MYRA — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mobile app (react-native-config) ─────────────────────────────────────────
# Read at build time by react-native-config.
# Local simulator default: use localhost.
# Physical iPhone: replace localhost with your Mac's LAN IP.
API_URL=http://localhost:5001
AI_BASE_URL=http://localhost:5002
ENABLE_AI=true

# ── Node.js Backend ───────────────────────────────────────────────────────────
# Generate a strong random string for JWT_SECRET and INTERNAL_TOKEN:
#   openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_DB=style_with_ai
NODE_PORT=5001
# Shared secret between Node and Python. Must match in both services.
INTERNAL_TOKEN=replace_with_a_long_random_string
# Local Python service URL used by Node.
AI_SERVICE_URL=http://127.0.0.1:5002
AI_TIMEOUT_MS=180000

# ── Python AI Service ─────────────────────────────────────────────────────────
# Run locally: uvicorn app:app --host 127.0.0.1 --port 5002 --reload
OPENAI_API_KEY=sk-replace-with-your-openai-key
# false = real MongoDB wardrobe, true = mock wardrobe data
AI_USE_MOCK_DB=false

# ── Weather (optional) ────────────────────────────────────────────────────────
# OpenWeatherMap API key — outfit suggestions degrade gracefully without this.
WEATHER_API_KEY=

# ── Cloudflare R2 (image upload — optional for local dev) ─────────────────────
# Only needed if testing image upload.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
RAW_R2_PREFIX=raw/
CLEAN_R2_PREFIX=clean/
