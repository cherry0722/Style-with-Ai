# ─────────────────────────────────────────────────────────────────────────────
# MYRA — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mobile app (react-native-config) ─────────────────────────────────────────
# Read at build time by react-native-config (not yet wired on iOS; src/config.ts
# DEV_FALLBACK values are the active fallback for dev builds).
# Set to Render URLs for device builds; leave empty to use src/config.ts defaults.
API_URL=https://style-with-ai-node.onrender.com
AI_BASE_URL=https://style-with-ai-python.onrender.com
ENABLE_AI=true

# ── Node.js Backend ───────────────────────────────────────────────────────────
JWT_SECRET=
MONGO_URI=
MONGO_DB=style_with_ai
NODE_PORT=5001
INTERNAL_TOKEN=
AI_SERVICE_URL=http://127.0.0.1:5002
AI_TIMEOUT_MS=180000

# ── Python AI Service ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Python service runs on port 5002 via: uvicorn app:app --port 5002

# ── Cloudflare R2 (image upload — optional for local dev) ─────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
RAW_R2_PREFIX=raw/
CLEAN_R2_PREFIX=clean/
