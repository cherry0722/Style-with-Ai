# ─────────────────────────────────────────────────────────────────────────────
# MYRA — Environment Variables
# Copy this file to .env and fill in the required values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mobile app (react-native-config) ─────────────────────────────────────────
# The iOS Simulator uses these Render URLs by default; no changes are needed for evaluation mode.
# react-native-config iOS wiring is deferred; src/config.ts Render fallbacks are active.
# Only change these if pointing to a different backend deployment.
API_URL=https://style-with-ai-node.onrender.com
AI_BASE_URL=https://style-with-ai-python.onrender.com
ENABLE_AI=true

# ── Node.js Backend ───────────────────────────────────────────────────────────
JWT_SECRET=
MONGO_URI=
MONGO_DB=style_with_ai
NODE_PORT=5001
# Shared secret used by Node backend to authenticate calls to the Python AI service.
# Must match the INTERNAL_TOKEN value set in the Python service environment.
# Use any 32+ character random string, e.g. openssl rand -hex 32
INTERNAL_TOKEN=
# For Render deployment: set this to your Render Python service URL.
# Leave as 127.0.0.1:5002 for local development.
AI_SERVICE_URL=http://127.0.0.1:5002
AI_TIMEOUT_MS=180000

# ── Python AI Service ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Python service runs on port 5002 via: uvicorn app:app --port 5002
# true = Python AI uses mock wardrobe data from backend/data/mock_closet.json
# false = Python AI reads from MongoDB and requires MONGO_URI
AI_USE_MOCK_DB=true

# OpenWeatherMap API key — optional; weather-aware outfit suggestions degrade gracefully without it
WEATHER_API_KEY=

# ── Cloudflare R2 (image upload — optional for local dev) ─────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
RAW_R2_PREFIX=raw/
CLEAN_R2_PREFIX=clean/
